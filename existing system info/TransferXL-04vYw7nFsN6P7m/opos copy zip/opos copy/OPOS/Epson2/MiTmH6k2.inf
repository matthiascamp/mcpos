;;;;;;;;;;;;;;;;;;;

[MAIN_4]
DeviceName		= TM-H6000IIE			; Device Name
DeviceDesc		= EPSON TM-H6000IIE MICR	; Device Description
GroupID			= Micrs_E			; Device Group

[SETTING_4]
Port			= TMPORT1			; Default IP Address
OutputBuf		= 1024

[DEVINFO_4]
Master			= "TM-H6000IIE"			; attachable Master device
