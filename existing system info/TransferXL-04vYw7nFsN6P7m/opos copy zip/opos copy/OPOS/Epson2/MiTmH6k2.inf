[MAIN]
DeviceClass		= MICR				; Device Class
DeviceName		= TM-H6000II			; Device Name
DeviceDesc		= EPSON TM-H6000II MICR		; Device Description
ModelName		= STRING:TM-H6000II		; Device Model Name
SOName			= SoEPSON.MICR.140		; Service Object Name
NumberOfDevice		= 4				; Number of Device
GroupID 		= Micrs				; Device Group
RegFormatType		= EPSON				; RegFormat Type
RegFormatVersion	= 2				; RegFormat Version
SupportCoreVersion	= STRING:1.14.0.0		; Support CoreModuleGroup Version
UseESDPRT		= INT:1				; EPSON SD Printer Port(Enable:1 Disable:0)

[DEVINFO]
INFVersion	= INT:001008000
InternalVersion	= int:200				; INF Version
PrinterDllName	= STRING:PtrH6k140.Dll			; DLL File Name

ReadCommand	= DWORD:30
DataWaitTime	= INT:35000
DeleteChar	= DWORD:03

SpecificSetting	= DWORD:01				; U675,H6000
RomIDBorder	= DWORD:FF	

CapASB		= DWORD:1101				; ASB Type(Normal, Ink, Extend, Custom)

DllName		= MiH6k140.dll

StatsUnifiedPOSVersion		= DWORD:101
StatsDeviceCategory		= DWORD:101
StatsManufacturerName		= DWORD:1420109
StatsModelName			= DWORD:1430109
StatsSerialNumber		= DWORD:1440109
StatsManufactureDate		= DWORD:101
StatsMechanicalRevision		= DWORD:101
StatsFirmwareRevision		= DWORD:1410109
StatsInterface			= DWORD:101
StatsInstallationDate		= DWORD:101

StatsHoursPoweredCount		= DWORD:2C6010B
StatsCommunicationErrorCount	= DWORD:107

StatsGoodReadCount		= DWORD:107
StatsFailedReadCount		= DWORD:107
StatsFailedDataParseCount	= DWORD:107

[SETTING]
INFVersion	= INT:001008000

IdleSleep	= INT:20				; sleep time(msec) in idle loop
Timeout		= INT:2500				; Output timeout time

ReadCommand	= DWORD:30
DataWaitTime	= INT:35000
DeleteChar	= DWORD:03

Settings	= DWORD:08

ValidationDevice	= DWORD:01

;;;;;;;;;;;;;;;;;;;
;; Serial
;;;;;;;;;;;;;;;;;;;

[MAIN_1]
DeviceName		= TM-H6000II			; Device Name
DeviceDesc		= EPSON TM-H6000II MICR		; Device Description
GroupID 		= Micrs				; Device Group

[PORT_1]
BaudrateSel		= 5,6,7,8			; 4800, 9600, 19200, 38400
BitLengthSel		= 0,1				; 7 bit, 8 bit
ParitySel		= 0,1,2				; NONE, EVEN, ODD
StopSel			= 1				; 1 bit only
XonXoffSel		= 0				; Disabled only
HandShakeSel		= 2				; DTR/DSR only

[SETTING_1]
Port			= TMPORT1			; Default COM Port
Baudrate		= 7				; 19200
BitLength		= 1				; 8 bit
Parity			= 0				; None
Stop			= 1				; 1 bit
XonXoff			= 0				; Disabled
HandShake		= 2				; DTR/DSR
OutputBuf		= 1024

[DEVINFO_1]
Master			= "TM-H6000II"			; attachable Master device

;;;;;;;;;;;;;;;;;;;
;; Parallel
;;;;;;;;;;;;;;;;;;;

[MAIN_2]
DeviceName		= TM-H6000IIP			; Device Name
DeviceDesc		= EPSON TM-H6000IIP MICR	; Device Description
GroupID			= Micrs_P			; Device Group

[SETTING_2]
Port			= TMPORT1			; Default LPT Port
OutputBuf		= 1024

[DEVINFO_2]
Master			= "TM-H6000IIP"			; attachable Master device

;;;;;;;;;;;;;;;;;;;
;; USB
;;;;;;;;;;;;;;;;;;;

[MAIN_3]
DeviceName		= TM-H6000IIU			; Device Name
DeviceDesc		= EPSON TM-H6000IIU MICR	; Device Description
GroupID			= Micrs_U			; Device Group

[SETTING_3]
Port			= TMPORT1			; Default USB Port

[DEVINFO_3]
Master			= "TM-H6000IIU"			; attachable Master device

;;;;;;;;;;;;;;;;;;;
