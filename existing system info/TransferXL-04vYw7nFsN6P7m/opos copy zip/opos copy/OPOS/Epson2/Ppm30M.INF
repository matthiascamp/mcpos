;;;;;;;;;;;;;;;;;;;
;; Common
;;;;;;;;;;;;;;;;;;;

[MAIN]
DeviceClass 		= STRING:POSPrinter				; Device Class
DeviceName		= STRING:TM-m30M					; Device Name
DeviceDesc		= STRING:EPSON TM-m30M POS Printer		; Device Description
ModelName		= STRING:TM-m30					; Device Model Name
SOName 			= STRING:SOEPSON.POSPrinterU.140		; SO Program ID
NumberOfDevice		= INT:3						; Number of Device
RegFormatType		= STRING:EPSON					; Registry Format
RegFormatVersion	= INT:2						; Registry Version
SupportCoreVersion	= STRING:1.14.1.0				; Support CoreModuleGroup Version
UseESDPRT		= INT:1						; EPSON SD Printer Port(Enable:1 Disable:0)

[PORT]
OutputLD		= INT:0				; Output to LineDisplay
OutputDK		= INT:1				; Output to Drawer
OutputMICR		= INT:0				; Enable MICR Device
OutputMin		= INT:32			; Minimum Bytes for Output
OutputMax		= INT:1024			; Maximum Bytes for Output
OutputEJ		= INT:1				; ElectronicJournal

[DEVINFO]
ConnectedSOName		= STRING:SOEPSON.POSPrinter.200	; SO Program ID
PrinterDllName		= STRING:PtrMobile1.Dll		; DLL File Name
InternalVersion		= INT:002000000			; INF File Version
CapRealtimeKick		= INT:01			; Real Time Kick Command for Drawer
PulseUNITTime		= INT:02			; Drawer Pulse UNIT (msec)
CapASB				= DWORD:01			; ASB Type(Normal, Ink, Extend, Custom)
DeviceID			= DWORD:9B
BmpFMemSize			= INT:393216

StatsUnifiedPOSVersion		= DWORD:101
StatsDeviceCategory		= DWORD:101
StatsManufacturerName		= DWORD:1420109
StatsModelName			= DWORD:1430109
StatsSerialNumber		= DWORD:1440109
StatsManufactureDate		= DWORD:101
StatsMechanicalRevision		= DWORD:101
StatsFirmwareRevision		= DWORD:1410109
StatsInterface			= DWORD:101
StatsInstallationDate		= DWORD:101
StatsHoursPoweredCount		= DWORD:2C6010B
StatsCommunicationErrorCount	= DWORD:107
StatsBarcodePrintedCount	= DWORD:107
StatsFormInsertionCount		= DWORD:111
StatsHomeErrorCount		= DWORD:111
StatsJournalCharacterPrintedCount	= DWORD:111
StatsJournalLinePrintedCount	= DWORD:111
StatsMaximumTempReachedCount	= DWORD:107
StatsNVRAMWriteCount		= DWORD:107
StatsPaperCutCount		= DWORD:2B2010B
StatsFailedPaperCutCount	= DWORD:107
StatsPrinterFaultCount		= DWORD:107
StatsPrintSideChangeCount	= DWORD:111
StatsFailedPrintSideChangeCount	= DWORD:111
StatsReceiptCharacterPrintedCount	= DWORD:107
StatsReceiptCoverOpenCount	= DWORD:107
StatsReceiptLineFeedCount	= DWORD:294010B
StatsReceiptLinePrintedCount	= DWORD:107
StatsSlipCharacterPrintedCount	= DWORD:111
StatsSlipCoverOpenCount		= DWORD:111
StatsSlipLineFeedCount		= DWORD:111
StatsSlipLinePrintedCount	= DWORD:111
StatsStampFiredCount		= DWORD:111

[SETTING]
InputBuf		= INT:1024			; Input Buffer
OutputBuf		= INT:1024			; Output Buffer
Timeout			= INT:2500			; Output Interval Time
IdleSleep		= INT:20			; Sleep Time(msec) in Idle Loop
InputSleep		= INT:10			; Sleep Time(msec) in Input Loop
OptionFirmVersion = DWORD:1			; Firm Version Check OFF
OptionPaperInvariable	= DWORD:0			; Invariable Paper Setting
OptionBmpRaster		= DWORD:1			; Raster Bitimage Setting
OptionBmpNvram 		= DWORD:0			; NVRAM Setting  ON:1	OFF:0
OptionSoundMelody	= DWORD:1			; SoundMelody 	ON:1	OFF:0
OptionSoundPatternCount	= DWORD:7			; Sound Melody Pattern Count
OptionBitmapGradation	= DWORD:1			; Gradation Setting  Grayscale:1
OptionNearEndSensorInstallation = DWORD:1 ; NearEndSensor Installation FALSE:0 TRUE:Other
OptionPaperIndex = DWORD:0				; PaperIndex
OptionEnablePaperTab = DWORD:1			; Display Paper Tab ON:1 OFF:0
DistanceBetweenHeadCutter	= DWORD:74		;DistanceBetweenHeadCutter
LogoToolPath	= STRING:\EPSON\TM-m30 Software\TMm30UTL\TMm30UTL.exe	; UTL Tool Install Path
OptionSoundPatternLengthList	= STRING:1200,1200,1500,800,1200,600,600	; Sound Melody Pattern Length List
OptionSoundPatternIDList	= STRING:1,2,3,4,5,100,101			; Sound Melody Pattern ID List
OptionThai1PassDevice = DWORD:1				; Thai1Pass Device

;;;;;;;;;;;;;;;;;;;
;; Bluetooth
;;;;;;;;;;;;;;;;;;;

[MAIN_1]
DeviceName		= STRING:TM-m30MB		; Device Name
DeviceDesc		= STRING:EPSON TM-m30MB POS Printer	; Device Description
GroupID			= STRING:Ptrs_B			; Device Group

[PORT_1]
OutputLD		= INT:2				; Output to LineDisplay

[SETTING_1]
Port			= STRING:TMPORT1		; Default Port

