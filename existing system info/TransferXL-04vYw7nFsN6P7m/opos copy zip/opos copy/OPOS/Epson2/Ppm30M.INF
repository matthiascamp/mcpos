;;;;;;;;;;;;;;;;;;;

[MAIN_2]
DeviceName		= STRING:TM-m30MU		; Device Name
DeviceDesc		= STRING:EPSON TM-m30MU POS Printer	; Device Description
GroupID			= STRING:Ptrs_U			; Device Group

[PORT_2]
OutputLD		= INT:2				; Output to LineDisplay

[SETTING_2]
