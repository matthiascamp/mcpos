DeviceName		= STRING:TM-T88VIMU_MltIF			; Device Name
DeviceDesc		= STRING:EPSON TM-T88VIMU_MltIF POS Printer	; Device Description
GroupID			= STRING:Ptrs_U					; Device Group

[SETTING_2]
