# Crisp POS Configuration
# Copy to .env and fill in your values

# Supabase (create a project at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Store identity (for multi-register setups)
STORE_ID=crisp-on-creek
REGISTER_ID=LANE01

# Hardware
RECEIPT_PRINTER=usb
# RECEIPT_PRINTER_VID=0x04b8
# RECEIPT_PRINTER_PID=0x0202
# SCALE_PORT=COM3
# SCALE_BAUD=9600

# Tyro EFTPOS (get from integrationsupport@tyro.com)
# TYRO_MERCHANT_ID=your-merchant-id
# TYRO_API_KEY=your-api-key
