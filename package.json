{
  "name": "tillaroo",
  "version": "1.0.0",
  "description": "Tillaroo POS — Electron + SQLite + Supabase",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "import": "node import-data.js",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "node-hid": "^3.1.0",
    "pg": "^8.20.0",
    "serialport": "^12.0.0",
    "sql.js": "^1.11.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "docx": "^9.6.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.tillaroo.pos",
    "productName": "Tillaroo",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "linkly.js",
      "lan-sync.js",
      "rawprint.ps1",
      "opos-bridge.ps1",
      "scale_reader.py",
      "scanner-bridge.exe",
      "package.json",
      "products.json",
      "keyboard-layout.json",
      "pos/**",
      "db/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "portable": {
      "artifactName": "Tillaroo-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "artifactName": "Tillaroo-Setup-${version}.exe"
    },
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  },
  "author": "Matthias Campbell",
  "license": "MIT"
}
